FROM rust:1.88-bookworm AS chef
WORKDIR /app

FROM chef AS planner
COPY Cargo.toml Cargo.lock* ./
COPY crates ./crates

FROM planner AS builder
RUN cargo build --release -p recipe-mixer-api

FROM gcr.io/distroless/cc-debian12:nonroot AS runtime
WORKDIR /app
COPY --from=builder /app/target/release/recipe-mixer-api /app/recipe-mixer-api
USER nonroot:nonroot
EXPOSE 8080
ENTRYPOINT ["/app/recipe-mixer-api"]
